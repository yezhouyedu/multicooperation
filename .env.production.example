# Copy this file to .env.production on the server.
# Do not commit the real .env.production.

POSTGRES_DB=multi_cooperation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_long_random_password

# P0 bare-IP deployment can expose these temporarily.
# After HTTPS is verified, keep 80/443 open and remove 3000/3001 from the public security group.
WEB_PUBLIC_PORT=3000
SERVER_PUBLIC_PORT=3001
HTTP_PUBLIC_PORT=80
HTTPS_PUBLIC_PORT=443
NGINX_CERT_DIR=/etc/multi-cooperation/certs

# Admin backend authentication. Change this value in the real server .env.production,
# then restart/rebuild the server service. Tokens are signed with this password by default,
# so old admin tokens become invalid after a password change.
ADMIN_PASSWORD=20260617
ADMIN_TOKEN_SECRET=

# HTTPS production uses the same domain and proxies /api to the NestJS server.
NEXT_PUBLIC_SERVER_BASE_URL=https://aiseek.tech/api

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional. Used by Experiment 1 / advanced AI. If left empty, the server falls back to the basic AI provider settings.
OPENAI_ADVANCED_BASE_URL=
OPENAI_ADVANCED_API_KEY=
OPENAI_ADVANCED_MODEL=

# Production container path for admin case library scanning.
CASE_LIBRARY_ROOT=/app/00_start_materials/原始材料

# Persistent server storage volume for materials, AI image attachments, exports, and temporary uploads.
STORAGE_ROOT=/app/storage
