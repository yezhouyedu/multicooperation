# Copy this file to .env.production on the server.
# Do not commit the real .env.production.

POSTGRES_DB=multi_cooperation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_long_random_password

# P0 bare-IP deployment can expose these temporarily.
# P1 should put Caddy/Nginx in front and stop exposing 3000/3001 publicly.
WEB_PUBLIC_PORT=3000
SERVER_PUBLIC_PORT=3001

# Before domain approval, use the bare IP server API.
# After domain/HTTPS, change to the final HTTPS API origin or same-domain proxy.
NEXT_PUBLIC_SERVER_BASE_URL=http://49.233.203.108:3001

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
